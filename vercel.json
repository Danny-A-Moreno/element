{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    { "src": "/style.css", "dest": "/api/style.css" },
    { "src": "/imagenes/(.*)", "dest": "/api/imagenes/$1" },
    { "src": "/busqueda-instantanea.js", "dest": "/api/busqueda-instantanea.js" },
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/(.*)", "dest": "/api/$1" }
  ]
}